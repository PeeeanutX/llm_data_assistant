# ============================================================================
#  Data Assistant — configuration template
#
#  HOW TO USE:
#    1. Make a copy of this file in the same folder and name the copy ".env"
#       (just a dot followed by "env", with no name in front).
#    2. Fill in the three lines marked  <-- CHANGE THIS
#    3. Save. That's it — the app reads ".env" automatically when it starts.
#
#  The real ".env" file is private and is never shared or uploaded (it is
#  listed in .gitignore). This ".env.example" file is safe to share because
#  it only contains placeholders, not real keys.
# ============================================================================

# --- OpenAI (REQUIRED) -------------------------------------------------------
# Your secret key from https://platform.openai.com/api-keys (it starts with "sk-").
OPENAI_API_KEY=sk-your-openai-key-here              # <-- CHANGE THIS

# Which OpenAI chat model to use. "gpt-5.4-mini" is the default.
# You can change it to any OpenAI chat model your account has access to.
OPENAI_MODEL=gpt-5.4-mini

# --- Database (REQUIRED) -----------------------------------------------------
# A PostgreSQL connection string. Every chat interaction is logged here.
# Easiest option (no install): create a free database at https://neon.tech and
# paste the connection string it gives you on the line below.
#   Local Postgres:   postgresql://postgres:postgres@localhost:5432/data_assistant
#   Docker compose:   postgresql://postgres:postgres@db:5432/data_assistant
DATABASE_URL=postgresql://user:password@host:5432/dbname    # <-- CHANGE THIS

# Name of the table the app logs to. It is created automatically on first run.
INTERACTIONS_TABLE=interactions_experiment
PG_POOL_MIN=1
PG_POOL_MAX=5

# --- Data source -------------------------------------------------------------
# The Excel workbook the assistant answers questions about (already included in
# the project). You normally do not need to change these.
EXCEL_FILE_PATH=(US)Sample-Superstore.xlsx
SQLITE_DB_PATH=database.db

# --- Confidence scoring (the "how sure am I?" feature) -----------------------
CONFIDENCE_VIEW=numerical
CONFIDENCE_K=5
CONFIDENCE_ROUNDS=3
CONFIDENCE_ALPHA=0.8
CONFIDENCE_BETA=0.7
CONFIDENCE_SAMPLE_TEMPERATURE=1.0
CONFIDENCE_USE_DIVERSITY_PROMPT=True

# Which language-comparison (NLI) model the confidence feature uses, and where
# it runs:
#   NLI_BACKEND=inference  -> runs over the internet on HuggingFace.
#                             Needs HF_API_TOKEN below. No heavy libraries to
#                             install. (Recommended easy path.)
#   NLI_BACKEND=local      -> runs on your own computer. No token needed, but
#                             downloads ~1.4 GB of AI libraries the first time.
NLI_MODEL=FacebookAI/roberta-large-mnli
NLI_BACKEND=inference

# Free token from https://huggingface.co/settings/tokens.
# Only used when NLI_BACKEND=inference. You can leave this as-is to start: the
# app still runs without it, the confidence score just won't be calculated.
HF_API_TOKEN=hf_your-huggingface-token-here         # <-- CHANGE THIS

# --- Advanced knobs (fine to leave exactly as they are) ----------------------
MAX_TOTAL_TOKENS=14600
RESERVED_TOKENS=1000
EXPLANATION_MAX_TOKENS=1000
EXPLANATION_TEMPERATURE=0.1
